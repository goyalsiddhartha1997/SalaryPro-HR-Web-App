rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Core validation helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Type and boundary constraints (Pillar 2: Validation Blueprints)
    function isValidEmployee(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.monthlySalary is number && data.monthlySalary >= 0 && data.monthlySalary <= 1000000
        && data.workingDays is number && data.workingDays >= 0 && data.workingDays <= 31
        && data.workingHours is number && data.workingHours >= 0 && data.workingHours <= 24
        && data.fullDaysAbsent is number && data.fullDaysAbsent >= 0 && data.fullDaysAbsent <= 31
        && data.absentHours is number && data.absentHours >= 0 && data.absentHours <= 24
        && data.absentMinutes is number && data.absentMinutes >= 0 && data.absentMinutes <= 59;
    }

    function isValidPunchLog(data) {
      return data.id is string && data.id.size() <= 64
        && data.employeeId is string && data.employeeId.size() <= 64
        && data.date is string && data.date.size() <= 64
        && data.punches is list && data.punches.size() <= 30;
    }

    function isValidGatePass(data) {
      return data.id is string && data.id.size() <= 128
        && data.employeeId is string && data.employeeId.size() <= 64
        && data.employeeName is string && data.employeeName.size() <= 128
        && data.date is string && data.date.size() <= 64
        && data.outTime is string && data.outTime.size() <= 64
        && data.inTime is string && data.inTime.size() <= 64
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    function isValidOvertimeLog(data) {
      return data.id is string && data.id.size() <= 128
        && data.employeeId is string && data.employeeId.size() <= 64
        && data.employeeName is string && data.employeeName.size() <= 128
        && data.date is string && data.date.size() <= 64
        && data.arrTime is string && data.arrTime.size() <= 64
        && data.outTime is string && data.outTime.size() <= 64
        && data.shiftPattern is string && data.shiftPattern.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 128
        && (!('remarks' in data) || data.remarks is string)
        && (!('empShift' in data) || data.empShift is string)
        && (!('empShiftTime' in data) || data.empShiftTime is string);
    }

    function isValidShiftRules(rules) {
      return rules.prependInCutoff is string && rules.prependInCutoff.size() <= 64
        && rules.prependInTime is string && rules.prependInTime.size() <= 64
        && rules.morningDupStart is string && rules.morningDupStart.size() <= 64
        && rules.morningDupEnd is string && rules.morningDupEnd.size() <= 64
        && rules.eveningDupStart is string && rules.eveningDupStart.size() <= 64
        && rules.eveningDupEnd is string && rules.eveningDupEnd.size() <= 64
        && rules.lunchStart is string && rules.lunchStart.size() <= 64
        && rules.lunchEnd is string && rules.lunchEnd.size() <= 64
        && rules.warningThreshold is number && rules.warningThreshold >= 0 && rules.warningThreshold <= 1440
        && rules.defaultExitTime is string && rules.defaultExitTime.size() <= 64;
    }

    function isValidSettings(data) {
      return data.dayRules is map && isValidShiftRules(data.dayRules)
        && data.nightRules is map && isValidShiftRules(data.nightRules);
    }

    function isValidLoomOrder(data) {
      return ('id' in data && data.id is string)
        && ('orderNo' in data && data.orderNo is string)
        && ('date' in data && data.date is string)
        && ('status' in data && data.status is string)
        && ('rows' in data && data.rows is list)
        && (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidCanteenFoodBill(data) {
      return data.id is string
        && data.challanNo is string
        && data.issuedBy is string
        && data.mealType is string
        && data.noOfMeals is number
        && (!('amount' in data) || data.amount is number || data.amount == null)
        && data.date is string
        && data.monthYear is string
        && (!('remarks' in data) || data.remarks is string);
    }

    function isValidRawMaterial(data) {
      return data.id is string
        && data.name is string
        && data.category is string
        && data.currentStock is number
        && data.unit is string
        && data.lastUpdated is string;
    }

    function isValidLoomProduction(data) {
      return data.id is string
        && data.date is string
        && data.isStopped is bool
        && (!('looms' in data) || data.looms == null || data.looms is number)
        && (!('production' in data) || data.production == null || data.production is number)
        && (!('average' in data) || data.average == null || data.average is number)
        && (!('wastage' in data) || data.wastage == null || data.wastage is number)
        && (!('createdAt' in data) || data.createdAt is string)
        && (!('shift' in data) || data.shift is string);
    }



    match /employees/{employeeId} {
      // Allow anybody to read the active ledger database (since it's a shared organizational sheet)
      allow read: if true;
      allow list: if true;

      // Allow write if signed in (secure Google OAuth authorization) OR if we are in public-mode for demo
      allow create: if isValidId(employeeId) 
        && isValidEmployee(incoming())
        && incoming().id == employeeId;

      allow update: if isValidId(employeeId)
        && isValidEmployee(incoming())
        && incoming().id == existing().id;

      allow delete: if isValidId(employeeId);

      match /punches/{date} {
        allow read, list: if true;
        allow create, update: if isValidId(employeeId) && isValidId(date) && isValidPunchLog(incoming()) && incoming().employeeId == employeeId;
        allow delete: if isValidId(employeeId) && isValidId(date);
      }

      match /monthlyPayroll/{yearMonth} {
        allow read, list: if true;
        allow create, update, delete: if isValidId(employeeId) && isValidId(yearMonth);
      }
    }

    match /recycle_bin/{employeeId} {
      allow read, list: if true;
      allow create, update, delete: if isValidId(employeeId);
    }

    match /{path=**}/punches/{date} {
      allow read, list: if true;
    }

    match /{path=**}/monthlyPayroll/{yearMonth} {
      allow read, list: if true;
    }

    match /custom_users/{email} {
      allow read, write: if true;
    }

    match /gatePasses/{passId} {
      allow read, list: if true;
      allow create, update: if isValidId(passId) && isValidGatePass(incoming()) && incoming().id == passId;
      allow delete: if isValidId(passId);
    }

    match /overtimeLogs/{logId} {
      allow read, list: if true;
      allow create, update: if isValidId(logId) && isValidOvertimeLog(incoming()) && incoming().id == logId;
      allow delete: if isValidId(logId);
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow create, update: if isValidId(settingsId) && isValidSettings(incoming());
    }

    match /loomOrders/{orderId} {
      allow read, list: if true;
      allow create, update: if isValidId(orderId) && isValidLoomOrder(incoming()) && incoming().id == orderId;
      allow delete: if isValidId(orderId);
    }

    match /canteenFoodBills/{billId} {
      allow read, list: if true;
      allow create, update: if isValidId(billId) && isValidCanteenFoodBill(incoming()) && incoming().id == billId;
      allow delete: if isValidId(billId);
    }

    match /rawMaterials/{itemId} {
      allow read, list: if true;
      allow create, update: if isValidId(itemId) && isValidRawMaterial(incoming()) && incoming().id == itemId;
      allow delete: if isValidId(itemId);
    }

    match /loomProductions/{productionId} {
      allow read, list: if true;
      allow create, update: if isValidId(productionId) && isValidLoomProduction(incoming()) && incoming().id == productionId;
      allow delete: if isValidId(productionId);
    }

  }
}
